# Copy to .env and edit. Compose reads .env automatically.
# For production: set strong values and do not commit .env.

# --- DB ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=habbits_galaxy

# --- Frontend Basic Auth (change in production) ---
AUTH_USER=admin
AUTH_PASS=admin

# --- Host port for frontend (Nginx) ---
FRONTEND_PORT=8088
